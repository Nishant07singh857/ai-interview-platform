# ============================================
# AI INTERVIEW PLATFORM - TEST ENVIRONMENT
# ============================================

ENVIRONMENT=test
DEBUG=True
SECRET_KEY=test-secret-key-not-for-production

# Firebase - Use test project
FIREBASE_DATABASE_URL=https://ai-interview-test.firebaseio.com
FIREBASE_STORAGE_BUCKET=ai-interview-test.appspot.com
FIREBASE_PROJECT_ID=ai-interview-test

# Redis - Use separate DB
REDIS_URL=redis://localhost:6379/15

# Database - Use test database
DATABASE_URL=postgresql://test_user:test_pass@localhost:5432/ai_interview_test

# Disable external services
OPENAI_API_KEY=test-key
GEMINI_API_KEY=test-key

# Use test Stripe keys
STRIPE_PUBLIC_KEY=pk_test_test
STRIPE_SECRET_KEY=sk_test_test

# Rate limiting disabled
RATE_LIMIT_REQUESTS=999999

LOG_LEVEL=DEBUG