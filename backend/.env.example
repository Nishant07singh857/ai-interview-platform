# ============================================
# AI INTERVIEW PLATFORM - BACKEND CONFIGURATION
# ============================================

# Application Configuration
# ----------------------------------------------------------------------
APP_NAME=AI Interview Platform
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=True
SECRET_KEY=your-super-secret-key-min-32-chars-change-in-production
API_V1_PREFIX=/api/v1

# Server Configuration
# ----------------------------------------------------------------------
HOST=0.0.0.0
PORT=8000
WORKERS=4
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Firebase Configuration
# ----------------------------------------------------------------------
# Get these from Firebase Console > Project Settings > Service Accounts
FIREBASE_CREDENTIALS=firebase-config.json
FIREBASE_DATABASE_URL=https://your-project-id.firebaseio.com
FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
FIREBASE_API_KEY=your-firebase-api-key
FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
FIREBASE_PROJECT_ID=your-project-id

# Redis Configuration
# ----------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=your-redis-password
REDIS_MAX_CONNECTIONS=10
REDIS_SOCKET_TIMEOUT=5
REDIS_SOCKET_CONNECT_TIMEOUT=5

# Celery Configuration
# ----------------------------------------------------------------------
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CELERY_TASK_ALWAYS_EAGER=False
CELERY_TASK_TIME_LIMIT=600
CELERY_TASK_SOFT_TIME_LIMIT=300

# Database (PostgreSQL - Optional)
# ----------------------------------------------------------------------
DATABASE_URL=postgresql://user:password@localhost:5432/ai_interview
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT=30

# AI Services
# ----------------------------------------------------------------------
# OpenAI - Get from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_ORG_ID=org-your-org-id
OPENAI_MODEL=gpt-4
OPENAI_MAX_TOKENS=2000
OPENAI_TEMPERATURE=0.7

# Google Gemini - Get from https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-pro

# Hugging Face - Get from https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=hf_your-huggingface-token
HUGGINGFACE_MODEL=microsoft/deberta-v3-base

# AWS Services
# ----------------------------------------------------------------------
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=ai-interview-platform

# Email Configuration (Gmail)
# ----------------------------------------------------------------------
# For Gmail: Enable 2FA and use App Password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@aiinterview.com
EMAIL_FROM_NAME=AI Interview Platform

# Payment Gateway (Stripe)
# ----------------------------------------------------------------------
# Get from https://dashboard.stripe.com/apikeys
STRIPE_PUBLIC_KEY=pk_test_your-stripe-public-key
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
STRIPE_CURRENCY=usd

# JWT Configuration
# ----------------------------------------------------------------------
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
BCRYPT_ROUNDS=12

# Rate Limiting
# ----------------------------------------------------------------------
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60

# File Upload
# ----------------------------------------------------------------------
MAX_UPLOAD_SIZE=10485760  # 10MB
ALLOWED_EXTENSIONS=.pdf,.docx,.txt,.jpg,.png,.jpeg
UPLOAD_PATH=uploads

# Logging
# ----------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s
LOG_MAX_BYTES=10485760  # 10MB
LOG_BACKUP_COUNT=5

# ML Models
# ----------------------------------------------------------------------
SKILL_EXTRACTOR_MODEL_PATH=ml_services/models/skill_extractor.pkl
READINESS_MODEL_PATH=ml_services/models/readiness_model.pkl
DIFFICULTY_CLASSIFIER_PATH=ml_services/models/difficulty_classifier.pkl
QUESTION_GENERATOR_PATH=ml_services/models/question_generator

# Cache
# ----------------------------------------------------------------------
CACHE_TTL=3600
CACHE_MAX_SIZE=1000

# Monitoring
# ----------------------------------------------------------------------
SENTRY_DSN=https://your-sentry-key@sentry.io/your-project-id
PROMETHEUS_ENABLED=True
METRICS_PORT=9090

# SSL (Production Only)
# ----------------------------------------------------------------------
SSL_ENABLED=False
SSL_KEYFILE=/path/to/privkey.pem
SSL_CERTFILE=/path/to/cert.pem