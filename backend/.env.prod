HUGGINGFACE_API_KEY=hf_prod_token_here

# AWS Services
AWS_ACCESS_KEY_ID=AKIAIPRODACCESSKEY
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYPRODSECRETKEY
