# Email Configuration (Production SMTP)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=SG.sendgrid_api_key_here
EMAIL_FROM=noreply@aiinterview.com
EMAIL_FROM_NAME=AI Interview Platform

# Payment Gateway (Stripe - Live Keys)
STRIPE_PUBLIC_KEY=pk_live_your-live-public-key
STRIPE_SECRET_KEY=sk_live_your-live-secret-key
STRIPE_WEBHOOK_SECRET=whsec_live_webhook_secret
