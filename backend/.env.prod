# JWT Configuration
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
BCRYPT_ROUNDS=12

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60

# File Upload
MAX_UPLOAD_SIZE=5242880  # 5MB
ALLOWED_EXTENSIONS=.pdf,.docx,.txt
UPLOAD_PATH=/data/uploads

# Logging
LOG_LEVEL=INFO
LOG_FILE=/var/log/app.log
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s
LOG_MAX_BYTES=104857600  # 100MB
LOG_BACKUP_COUNT=10

# ML Models
SKILL_EXTRACTOR_MODEL_PATH=/app/ml_services/models/skill_extractor.pkl
READINESS_MODEL_PATH=/app/ml_services/models/readiness_model.pkl
DIFFICULTY_CLASSIFIER_PATH=/app/ml_services/models/difficulty_classifier.pkl

# Cache
CACHE_TTL=3600
CACHE_MAX_SIZE=5000

# Monitoring
SENTRY_DSN=https://sentry-key@sentry.io/prod-project
PROMETHEUS_ENABLED=True
METRICS_PORT=9090

# SSL
SSL_ENABLED=True
SSL_KEYFILE=/etc/nginx/ssl/privkey.pem
SSL_CERTFILE=/etc/nginx/ssl/cert.pem